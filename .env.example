NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-new-service-role-key
APP_BASE_URL=http://localhost:3000
APP_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Graphify (knowledge graph) - output directory.
# All graphify artifacts live here instead of the project root.
GRAPHIFY_OUT=docs/graphify-out

# Graphify semantic pass - OpenAI-compatible backend via OpenRouter (optional).
# The default workflow (`python -m graphify update . --force`) is AST-only and
# consumes zero LLM tokens. Set these only when running `graphify extract` with
# the OpenRouter backend as a cloud fallback.
OPENROUTER_API_KEY=your-openrouter-key-if-enabled
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=your-openrouter-key-if-enabled
OPENAI_MODEL=openai/gpt-4.1-mini

# Context Memory Layer (PRD-CML-001)
CTX_EMBEDDING_PROVIDER=openrouter
OPENAI_EMBEDDING_MODEL=openai/text-embedding-3-small
CTX_GENERATE_SUMMARIES=false
CTX_CHUNK_MIN_TOKENS=800
CTX_CHUNK_MAX_TOKENS=1200
CTX_CHUNK_OVERLAP_TOKENS=80
CTX_DEFAULT_TOKEN_BUDGET=8000
STRIPE_SECRET_KEY=sk_test_or_live_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_BUSINESS_PRICE_ID=price_business_subscription
STRIPE_CORPORATE_PRICE_ID=price_corporate_subscription
