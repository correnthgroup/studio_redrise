NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-new-service-role-key
APP_BASE_URL=http://localhost:3000
APP_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# PRD-024 rollout flags (server-only). Default off: o Workstation continua no
# adaptador em memória. "WORKSTATION_DURABLE=true" liga a validação durável;
# WORKSTATION_DURABLE_ORGS aceita allowlist de slugs separada por vírgula ("*" = todas).
WORKSTATION_DURABLE=false
WORKSTATION_DURABLE_ORGS=*

# Graphify (knowledge graph) - output directory.
# All graphify artifacts live here instead of the project root.
GRAPHIFY_OUT=docs/graphify-out

# Graphify semantic extraction uses the central wrapper and the user-scoped
# CORRENTH_GRAPHIFY_OPENROUTER_API_KEY. Do not add that credential here.

# Shared CML consumer (server-only; never expose with NEXT_PUBLIC_)
CML_API_BASE_URL=
CML_CONSUMER_ACCESS_TOKEN=

STRIPE_SECRET_KEY=sk_test_or_live_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_BUSINESS_PRICE_ID=price_business_subscription
STRIPE_CORPORATE_PRICE_ID=price_corporate_subscription

# Playwright confirmed test account (local/CI secrets only)
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
